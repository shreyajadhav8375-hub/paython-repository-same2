def calculate_emi(loan_amount, annual_rate, years):
    monthly_rate = annual_rate / (12 * 100)   # Convert annual rate to monthly decimal
    months = years * 12

    emi = (loan_amount * monthly_rate * (1 + monthly_rate) ** months) / \
          ((1 + monthly_rate) ** months - 1)

    return emi

# Example usage
loan = float(input("Enter loan amount: "))
rate = float(input("Enter annual interest rate (%): "))
time = int(input("Enter time (years): "))

emi = calculate_emi(loan, rate, time)
print("Monthly EMI:", round(emi, 2))
